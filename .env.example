# Music Together environment variables
#
# Development:
#   The server process may run with packages/server as its cwd. For pnpm dev,
#   setting variables in the current PowerShell session is the most reliable:
#   $env:SERVER_ADMIN_IDS="your-account-id"; pnpm dev
#
# Docker Compose:
#   Copy this file to .env in the project root, edit values, then run:
#   docker compose up -d --build

# Host port exposed by docker-compose.yml.
HOST_PORT=3001

# Server runtime.
PORT=3001
NODE_ENV=production

# Optional CORS allow-list. Empty means auto mode.
CLIENT_URL=
CORS_ORIGINS=

# Identity cookie signing secret. Change this in production.
IDENTITY_SECRET=dev-identity-secret-change-me
IDENTITY_TTL_DAYS=30
IDENTITY_COOKIE_SECURE=false
REJOIN_TTL_MS=30000

# SQLite database path. In Docker keep it under /app/data.
DATABASE_URL=file:/app/data/music-together.db

# Comma-separated persistent account IDs with server-admin permission.
# Open Settings -> Identity, copy the account ID, then set it here and restart.
SERVER_ADMIN_IDS=

# Auto fallback between supported platforms.
AUTO_FALLBACK_ENABLED=true

# UNM HTTP proxy URL. For same Docker network, use the service/container name.
# Example: UNM_SERVER_URL=http://unm-server:80
UNM_SERVER_URL=
UNM_SERVER_TIMEOUT_MS=10000
